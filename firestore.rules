rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Portfolios collection: Everyone can read, anyone can write (since local admin login is used)
    match /portfolios/{portfolioId} {
      allow read, write: if true;
    }
    
    // Inquiries collection: Anyone can create (submit), everyone can read/write for local dashboard view
    match /inquiries/{inquiryId} {
      allow read, write: if true;
    }
  }
}
